            <column aggregation='Sum' caption='Experience_Max' datatype='integer' name='[Calculation_1658308035940380]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='INT(&#10;SPLIT(&#10;SPLIT([Experience], &quot; to &quot;, 2),&#10;&quot; &quot;,&#10;1&#10;)&#10;)' />
            </column>
            <column caption='Asia_Not_I' datatype='string' name='[Calculation_1658323674636325]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF LEFT([Country],1) = &quot;I&quot; THEN &quot;NO&quot;&#10;&#10;ELSEIF [Country] IN (&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&#10;&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&#10;&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&#10;&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&#10;&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&#10;&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#10;)&#10;THEN &quot;YES&quot;&#10;&#10;ELSE &quot;NO&quot;&#10;END' />
            </column>
            <column caption='Company_2_Vowels' datatype='boolean' name='[Calculation_1658323674791974]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='(LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;a&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;e&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;i&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;o&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;u&quot;,&quot;&quot;))&#10;) &gt;= 2' />
            </column>
            <column caption='Show_3to5PM_Param' datatype='boolean' name='[Calculation_1658325055000620]' role='dimension' type='nominal'>
