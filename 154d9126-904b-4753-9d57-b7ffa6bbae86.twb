            <column caption='Country_Not_ABCD_6' datatype='string' name='[Calculation_1658323681095721]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT (UPPER(LEFT([Country],1)) IN (&quot;A&quot;,&quot;B&quot;,&quot;C&quot;,&quot;D&quot;))&#10;THEN &quot;YES&quot;&#10;ELSE &quot;NO&quot;&#10;END' />
