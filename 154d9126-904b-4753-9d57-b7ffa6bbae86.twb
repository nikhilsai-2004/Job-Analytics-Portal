              <calculation class='tableau' formula='INT(&#10;REPLACE(&#10;REPLACE(&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#10;&quot;$&quot;,&quot;&quot;&#10;),&#10;&quot;K&quot;,&quot;000&quot;&#10;)&#10;)' />
