      <aliases enabled='yes' />
      <column caption='Country_Not_ABCD' datatype='boolean' name='[Calculation_1658307409637384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT (&#10;STARTSWITH([Country],&quot;A&quot;) OR&#10;STARTSWITH([Country],&quot;B&quot;) OR&#10;STARTSWITH([Country],&quot;C&quot;) OR&#10;STARTSWITH([Country],&quot;D&quot;)&#10;)' />
      </column>
      <column caption='JobTitle_SingleWord' datatype='boolean' name='[Calculation_1658307410042889]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT CONTAINS([Job Title], &quot; &quot;)' />
      </column>
      <column caption='JobTitle_Less10' datatype='boolean' name='[Calculation_1658307410214922]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Job Title]) &lt; 10' />
      </column>
      <column caption='Salary_Min' datatype='integer' name='[Calculation_1658307411791883]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#10;REPLACE(&#10;REPLACE(&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#10;&quot;$&quot;,&quot;&quot;&#10;),&#10;&quot;K&quot;,&quot;000&quot;&#10;)&#10;)' />
      </column>
      <column caption='Experience_Num' datatype='integer' name='[Calculation_1658307415150609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#10;IFNULL(&#10;REGEXP_EXTRACT([Experience], &quot;(\\d+)&quot;),&#10;&quot;0&quot;&#10;)&#10;)' />
      </column>
      <column caption='Experience_Even_OK' datatype='boolean' name='[Calculation_1658307415207954]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1658307415150609] % 2 = 0' />
      </column>
      <column caption='Odd_Month' datatype='boolean' name='[Calculation_1658307415601171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;,[Job Posting Date]) % 2 = 1' />
      </column>
      <column caption='Show_3to5PM' datatype='boolean' name='[Calculation_1658307417010196]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, DATEADD(&apos;minute&apos;, 330, NOW())) &gt;= 15&#10;AND DATEPART(&apos;hour&apos;, DATEADD(&apos;minute&apos;, 330, NOW())) &lt; 17' />
      </column>
      <column caption='Location_Not_Blank' datatype='boolean' name='[Calculation_1658308032868378]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([location])' />
      </column>
      <column caption='Company_morethan_8' datatype='boolean' name='[Calculation_1658308033097755]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN([Company]) &gt; 8' />
      </column>
      <column aggregation='Sum' caption='Experience_Max' datatype='integer' name='[Calculation_1658308035940380]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT(&#10;SPLIT(&#10;SPLIT([Experience], &quot; to &quot;, 2),&#10;&quot; &quot;,&#10;1&#10;)&#10;)' />
      </column>
      <column caption='Experience_Min' datatype='integer' name='[Calculation_1658308037668893]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SPLIT([Experience], &quot; to &quot;, 1))' />
      </column>
      <column caption='Experience_Clean' datatype='string' name='[Calculation_1658308038705182]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LOWER(TRIM([Experience]))' />
      </column>
      <column caption='Country_Task3' datatype='string' name='[Calculation_1658323627126815]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([Country],1) = &quot;C&quot; THEN &quot;NO&quot;&#10;&#10;ELSEIF [Country] IN (&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;India&quot;,&quot;Indonesia&quot;,&quot;Iran&quot;,&quot;Iraq&quot;,&quot;Israel&quot;,&#10;&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&#10;&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&#10;&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&#10;&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&#10;&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#10;) THEN &quot;NO&quot;&#10;&#10;ELSE &quot;YES&quot;&#10;END' />
      </column>
      <column caption='Contact_End_Vowel' datatype='string' name='[Calculation_1658323629281312]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF RIGHT(LOWER([Contact Person]),1) IN (&quot;a&quot;,&quot;e&quot;,&quot;i&quot;,&quot;o&quot;,&quot;u&quot;) THEN &quot;YES&quot;&#10;ELSE &quot;NO&quot;&#10;END' />
      </column>
      <column caption='Only_Africa' datatype='string' name='[Calculation_1658323662880801]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] IN (&#10;&quot;Algeria&quot;,&quot;Angola&quot;,&quot;Benin&quot;,&quot;Botswana&quot;,&quot;Burkina Faso&quot;,&quot;Burundi&quot;,&#10;&quot;Cabo Verde&quot;,&quot;Cameroon&quot;,&quot;Central African Republic&quot;,&quot;Chad&quot;,&quot;Comoros&quot;,&#10;&quot;Congo&quot;,&quot;Democratic Republic of the Congo&quot;,&quot;Djibouti&quot;,&quot;Egypt&quot;,&#10;&quot;Equatorial Guinea&quot;,&quot;Eritrea&quot;,&quot;Eswatini&quot;,&quot;Ethiopia&quot;,&quot;Gabon&quot;,&quot;Gambia&quot;,&#10;&quot;Ghana&quot;,&quot;Guinea&quot;,&quot;Guinea-Bissau&quot;,&quot;Ivory Coast&quot;,&quot;Kenya&quot;,&quot;Lesotho&quot;,&#10;&quot;Liberia&quot;,&quot;Libya&quot;,&quot;Madagascar&quot;,&quot;Malawi&quot;,&quot;Mali&quot;,&quot;Mauritania&quot;,&quot;Mauritius&quot;,&#10;&quot;Morocco&quot;,&quot;Mozambique&quot;,&quot;Namibia&quot;,&quot;Niger&quot;,&quot;Nigeria&quot;,&quot;Rwanda&quot;,&#10;&quot;Sao Tome and Principe&quot;,&quot;Senegal&quot;,&quot;Seychelles&quot;,&quot;Sierra Leone&quot;,&quot;Somalia&quot;,&#10;&quot;South Africa&quot;,&quot;South Sudan&quot;,&quot;Sudan&quot;,&quot;Tanzania&quot;,&quot;Togo&quot;,&quot;Tunisia&quot;,&#10;&quot;Uganda&quot;,&quot;Zambia&quot;,&quot;Zimbabwe&quot;&#10;)&#10;THEN &quot;YES&quot;&#10;ELSE &quot;NO&quot;&#10;END' />
      </column>
      <column caption='Show_3to6PM' datatype='boolean' name='[Calculation_1658323666145314]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, NOW()) &gt;= 15&#10;AND DATEPART(&apos;hour&apos;, NOW()) &lt; 18' />
      </column>
      <column caption='Salary_Min_20K' datatype='integer' name='[Calculation_1658323666989091]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#10;REPLACE(&#10;REPLACE(&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#10;&quot;$&quot;,&quot;&quot;&#10;),&#10;&quot;K&quot;,&quot;&quot;&#10;)&#10;)' />
      </column>
      <column caption='Salary_Above20' datatype='string' name='[Calculation_1658323667062820]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1658323666989091] &gt; 20 THEN &quot;YES&quot; ELSE &quot;NO&quot; END' />
      </column>
      <column caption='Asia_Not_I' datatype='string' name='[Calculation_1658323674636325]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([Country],1) = &quot;I&quot; THEN &quot;NO&quot;&#10;&#10;ELSEIF [Country] IN (&#10;&quot;Afghanistan&quot;,&quot;Armenia&quot;,&quot;Azerbaijan&quot;,&quot;Bahrain&quot;,&quot;Bangladesh&quot;,&quot;Bhutan&quot;,&quot;Brunei&quot;,&#10;&quot;Cambodia&quot;,&quot;China&quot;,&quot;Cyprus&quot;,&quot;Georgia&quot;,&quot;Japan&quot;,&quot;Jordan&quot;,&quot;Kazakhstan&quot;,&quot;Kuwait&quot;,&#10;&quot;Kyrgyzstan&quot;,&quot;Laos&quot;,&quot;Lebanon&quot;,&quot;Malaysia&quot;,&quot;Maldives&quot;,&quot;Mongolia&quot;,&quot;Myanmar&quot;,&#10;&quot;Nepal&quot;,&quot;North Korea&quot;,&quot;Oman&quot;,&quot;Pakistan&quot;,&quot;Palestine&quot;,&quot;Philippines&quot;,&quot;Qatar&quot;,&#10;&quot;Russia&quot;,&quot;Saudi Arabia&quot;,&quot;Singapore&quot;,&quot;South Korea&quot;,&quot;Sri Lanka&quot;,&quot;Syria&quot;,&quot;Taiwan&quot;,&#10;&quot;Tajikistan&quot;,&quot;Thailand&quot;,&quot;Timor-Leste&quot;,&quot;Turkey&quot;,&quot;Turkmenistan&quot;,&#10;&quot;United Arab Emirates&quot;,&quot;Uzbekistan&quot;,&quot;Vietnam&quot;,&quot;Yemen&quot;&#10;)&#10;THEN &quot;YES&quot;&#10;&#10;ELSE &quot;NO&quot;&#10;END' />
      </column>
      <column caption='Company_2_Vowels' datatype='boolean' name='[Calculation_1658323674791974]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='(LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;a&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;e&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;i&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;o&quot;,&quot;&quot;))&#10;+ LEN([Company]) - LEN(REPLACE(LOWER([Company]),&quot;u&quot;,&quot;&quot;))&#10;) &gt;= 2' />
      </column>
      <column caption='Show_3to5PM_Task2' datatype='boolean' name='[Calculation_1658323675062311]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] &gt;= 15 AND [Parameters].[Parameter 1] &lt; 17' />
      </column>
      <column caption='Country_Not_ABCD_6' datatype='string' name='[Calculation_1658323681095721]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF NOT (UPPER(LEFT([Country],1)) IN (&quot;A&quot;,&quot;B&quot;,&quot;C&quot;,&quot;D&quot;))&#10;THEN &quot;YES&quot;&#10;ELSE &quot;NO&quot;&#10;END' />
      </column>
      <column caption='JobTitle_Valid' datatype='string' name='[Calculation_1658323681796138]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEN([Job Title]) &lt; 10 &#10;AND NOT CONTAINS([Job Title], &quot; &quot;)&#10;THEN &quot;YES&quot;&#10;ELSE &quot;NO&quot;&#10;END' />
      </column>
      <column caption='Even_Experience' datatype='boolean' name='[Calculation_1658323682328619]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1658308035940380] % 2 = 0' />
      </column>
      <column caption='Show_3to5PM_Param' datatype='boolean' name='[Calculation_1658325055000620]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] &gt;= 15 AND [Parameters].[Parameter 1] &lt; 17' />
      </column>
