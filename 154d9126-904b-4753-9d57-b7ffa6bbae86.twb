              <calculation class='tableau' formula='NOT (&#10;STARTSWITH([Country],&quot;A&quot;) OR&#10;STARTSWITH([Country],&quot;B&quot;) OR&#10;STARTSWITH([Country],&quot;C&quot;) OR&#10;STARTSWITH([Country],&quot;D&quot;)&#10;)' />
            </column>
            <column caption='JobTitle_SingleWord' datatype='boolean' name='[Calculation_1658307410042889]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT CONTAINS([Job Title], &quot; &quot;)' />
            </column>
            <column caption='JobTitle_Less10' datatype='boolean' name='[Calculation_1658307410214922]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEN([Job Title]) &lt; 10' />
            </column>
            <column caption='Salary_Min' datatype='integer' name='[Calculation_1658307411791883]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#10;REPLACE(&#10;REPLACE(&#10;SPLIT([Salary Range], &quot;-&quot;, 1),&#10;&quot;$&quot;,&quot;&quot;&#10;),&#10;&quot;K&quot;,&quot;000&quot;&#10;)&#10;)' />
            </column>
            <column caption='Experience_Num' datatype='integer' name='[Calculation_1658307415150609]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(&#10;IFNULL(&#10;REGEXP_EXTRACT([Experience], &quot;(\\d+)&quot;),&#10;&quot;0&quot;&#10;)&#10;)' />
            </column>
            <column caption='Experience_Even_OK' datatype='boolean' name='[Calculation_1658307415207954]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_1658307415150609] % 2 = 0' />
            </column>
            <column caption='Odd_Month' datatype='boolean' name='[Calculation_1658307415601171]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATEPART(&apos;month&apos;,[Job Posting Date]) % 2 = 1' />
